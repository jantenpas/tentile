{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "cdk.out",
    "rootDir": ".",
    "skipLibCheck": true
  },
  "include": ["bin", "lib"],
  "exclude": ["node_modules", "cdk.out"]
}
